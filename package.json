{
  "name": "zzfx-studio-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter zzfx-studio run web",
    "preview": "pnpm --filter zzfx-studio run preview"
