{
  "name": "zzfx-studio-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter @zzfx-studio/app run web",
    "preview": "pnpm --filter @zzfx-studio/app run preview",
    "changeset": "changeset",
    "changeset:generate": "tsx scripts/generate-changesets.ts",
    "changeset:version": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@shopify/react-native-skia",
      "esbuild"
    ],
    "overrides": {
      "@zzfx-studio/zzfxm": "workspace:*"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "tsx": "^4.21.0",
    "turbo": "^2.7.5"
  }
}
