{
  "name": "zzfx-studio",
  "version": "0.1.2",
  "description": "Algorithmic chiptune tracker — generate 4-channel retro songs instantly",
  "license": "MIT",
  "type": "module",
  "bin": {
    "zzfx-studio": "./bin/zzfx-studio.js"
  },
  "files": [
    "bin"
  ],
  "scripts": {
    "build": "node scripts/build-platforms.js",
    "clean": "rm -rf resources dist bin/neutralino-* bin/neutralino.exe platforms/*/bin platforms/*/resources.neu"
  },
  "devDependencies": {
    "@neutralinojs/neu": "^11.7.0",
    "@zzfx-studio/app": "workspace:*"
  },
  "optionalDependencies": {
    "@zzfx-studio/platform-darwin-arm64": "workspace:*",
    "@zzfx-studio/platform-darwin-x64": "workspace:*",
    "@zzfx-studio/platform-linux-x64": "workspace:*",
    "@zzfx-studio/platform-linux-arm64": "workspace:*",
    "@zzfx-studio/platform-win32-x64": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thejustinwalsh/zzfx-studio.git",
    "directory": "packages/zzfx-studio"
  },
  "homepage": "https://thejustinwalsh.github.io/zzfx-studio",
  "author": "Justin Walsh (https://github.com/thejustinwalsh)",
  "keywords": [
    "zzfx",
    "zzfxm",
    "chiptune",
    "tracker",
    "retro",
    "audio",
    "music",
    "game-audio",
    "synthesizer",
    "8-bit",
    "chip-music",
    "game-jam",
    "demoscene",
    "algorithmic-music",
    "desktop-app",
    "npx"
  ]
}
