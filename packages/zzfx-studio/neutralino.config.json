{
  "applicationId": "studio.zzfx.app",
  "version": "0.1.0",
  "defaultMode": "window",
  "url": "/",
  "documentRoot": "/resources/",
  "port": 0,
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "dataLocation": "system",
  "storageLocation": "system",
  "nativeAllowList": [
    "app.exit",
    "events.*",
    "os.showSaveDialog",
    "os.showOpenDialog",
    "filesystem.readFile",
    "filesystem.writeFile",
    "filesystem.writeBinaryFile",
    "window.setMainMenu"
  ],
  "singlePageServe": true,
  "modes": {
    "window": {
      "title": "ZzFX Studio",
      "width": 1280,
      "height": 800,
      "minWidth": 800,
      "minHeight": 600,
      "center": true,
      "resizable": true,
      "enableInspector": false,
      "icon": "/resources/icon-512.png",
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "zzfx-studio",
    "resourcesPath": "/resources/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "6.5.0",
    "clientVersion": "6.5.0"
  }
}
