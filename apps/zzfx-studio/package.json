{
  "name": "zzfx-studio",
  "version": "0.1.0",
  "private": true,
  "main": "index",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "postinstall": "pnpm run build:worker && npx workbox-cli copyLibraries public/",
    "build:worker": "esbuild src/engine/render-worker.ts --bundle --outfile=public/render-worker.js --format=iife --minify --tree-shaking=true --target=es2020 --inject:src/engine/worker-polyfill.ts",
    "build:web": "pnpm run build:worker && npx expo export --platform web && node -e \"fs=require('fs');p=require('./package.json');fs.writeFileSync('dist/version.json',JSON.stringify({version:p.version}))\" && npx workbox-cli injectManifest workbox-config.js",
    "preview": "pnpm run build:web && npx serve dist -l 3000"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.6",
    "@zzfx-studio/zzfxm": "workspace:*",
    "@shopify/flash-list": "^2.3.0",
    "@shopify/react-native-skia": "~2.4.18",
    "@snapp-notes/react-native-syntax-highlighter": "^2.3.1",
    "expo": "~55.0.5",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-reanimated": "~4.2.1",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.2",
    "react-syntax-highlighter": "^15.6.6",
    "zzfx": "catalog:",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.2.2",
    "esbuild": "^0.27.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "workbox-cli": "^7.4.0"
  }
}
